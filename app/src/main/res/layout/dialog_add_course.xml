<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/courseNameEt"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Course Name"
        android:inputType="text"
        android:padding="12dp"
        android:background="@drawable/edit_text_background"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/courseCodeEt"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Course Code (e.g., CS101)"
        android:inputType="text"
        android:padding="12dp"
        android:background="@drawable/edit_text_background"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/courseTeacherEt"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Teacher Name"
        android:inputType="text"
        android:padding="12dp"
        android:background="@drawable/edit_text_background"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/courseSemesterEt"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Semester (e.g., Fall 2024)"
        android:inputType="text"
        android:padding="12dp"
        android:background="@drawable/edit_text_background"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/courseCreditsEt"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Credits"
        android:inputType="number"
        android:padding="12dp"
        android:background="@drawable/edit_text_background" />

</LinearLayout>

